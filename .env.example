# ── Required ──────────────────────────────────────────────────────────────────

# Site password — shared with stakeholders alongside the URL
ACCESS_TOKEN=YOUR_SITE_PASSWORD

# Your Vercel deployment URL — used for OG tags and magic links
NEXT_PUBLIC_BASE_URL=https://your-project-slug.vercel.app

# Random 32-character string — signs magic link JWTs
# Generate one: openssl rand -hex 32
MAGIC_LINK_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────

# Resend API key — enables magic link email access (passwordless entry)
# Get one at resend.com — free tier covers typical usage
RESEND_API_KEY=
